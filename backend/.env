# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Docker Compose)
MONGO_URI=mongodb://admin:password123@mongo:27017/mediscribe-ai?authSource=admin

# Redis Configuration (Docker Compose)
REDIS_URL=redis://:redispassword123@redis:6379

# Groq API Configuration (for Summary Generation)
GROQ_API_KEY=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

# Google AI Configuration
# Get your Gemini API key from: https://ai.google.dev/
GEMINI_API_KEY=demo_key_placeholder

# Google Cloud Configuration (for Speech-to-Text)
# Create a service account in Google Cloud Console and download the JSON key file
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id
GOOGLE_CLOUD_KEY_FILE=./path/to/your/service-account-key.json

# JWT Configuration
JWT_SECRET=dev_jwt_secret_key_change_in_production

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Upload Configuration
MAX_FILE_SIZE=50MB
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
